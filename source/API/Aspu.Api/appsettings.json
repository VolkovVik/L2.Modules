{
  "ApiVersion": {
    "Versions": [2],
    "DefaultVersion": 1
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Mqtt": {
    "Enabled": false,
    "Host": "mosquitto",
    "Port": 1883,
    "ClientId": null,
    "Username": null,
    "Password": null,
    "UseTls": false,
    "AllowUntrustedCertificates": false,
    "CleanSession": true,
    "KeepAliveSeconds": 60,
    "ReconnectDelaySeconds": 5,
    "QualityOfServiceLevel": "AtMostOnce",
    "SubscribeTopics": []
  }
}
