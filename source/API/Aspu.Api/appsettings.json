{
  "ApiVersion": {
    "Versions": [1, 2],
    "DefaultVersion": 1
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Mqtt": {
    "Enabled": false,
    "Host": "localhost",
    "Port": 1883,
    "ClientId": null,
    "Username": null,
    "Password": null,
    "UseTls": false,
    "AllowUntrustedCertificates": false,
    "CleanSession": true,
    "ReconnectDelaySeconds": 5,
    "ConnectionQuality": {
      "KeepAliveSeconds": 0,
      "CommunicationTimeoutSeconds": 0,
      "SubscribeQualityOfService": 0
    },
    "SubscribeTopics": []
  }
}
