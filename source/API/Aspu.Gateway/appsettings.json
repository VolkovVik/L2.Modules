{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Gateway": {
    "SignalRHubPath": "/notifications-hub"
  },
  "ReverseProxy": {
    "Routes": {
      "signalr-hub": {
        "ClusterId": "aspu-api",
        "Order": 0,
        "Match": {
          "Path": "/notifications-hub/{**remainder}"
        },
        "Transforms": [
          {
            "Forwarded": "by,for,host,proto",
            "Action": "Append"
          },
          {
            "RequestHeaderOriginalHost": "true"
          }
        ]
      },
      "signalr-hub-root": {
        "ClusterId": "aspu-api",
        "Order": 1,
        "Match": {
          "Path": "/notifications-hub"
        },
        "Transforms": [
          {
            "Forwarded": "by,for,host,proto",
            "Action": "Append"
          },
          {
            "RequestHeaderOriginalHost": "true"
          }
        ]
      },
      "aspu-api": {
        "ClusterId": "aspu-api",
        "Order": 100,
        "Match": {
          "Path": "{**catch-all}"
        },
        "Transforms": [
          {
            "Forwarded": "by,for,host,proto",
            "Action": "Append"
          },
          {
            "RequestHeaderOriginalHost": "true"
          }
        ]
      }
    },
    "Clusters": {
      "aspu-api": {
        "Destinations": {
          "aspu-api": {
            "Address": "http://aspu.api:8080/"
          }
        },
        "HttpRequest": {
          "ActivityTimeout": "00:05:00"
        }
      }
    }
  }
}
